{
  "case_id": "plan-02-from-failed-negative",
  "skill": "plan",
  "assertions": [
    { "id": "a1", "text": "state remains Failed (no implicit advance)", "source": "rubrix.json", "check": "json_path_equals", "path": "$.state", "expected": "Failed" },
    { "id": "a2", "text": "locks.plan remains true while still in Failed", "source": "rubrix.json", "check": "json_path_equals", "path": "$.locks.plan", "expected": true },
    { "id": "a3", "text": "scores remain populated as the failure commitment signal", "source": "rubrix.json", "check": "json_array_length_equals", "path": "$.scores", "expected": 2 },
    { "id": "a4", "text": "stdout or stderr explains failed-state recovery (PlanDrafted transition)", "source": ["stdout.txt", "stderr.txt"], "check": "text_contains_any", "expected_substrings": ["Failed", "PlanDrafted", "rubrix state set", "recover", "loop", "iterate"] },
    { "id": "a5", "text": "no schema-invalid failure.reason field is added", "source": "rubrix.json", "check": "json_path_absent", "path": "$.failure" }
  ]
}
