{
  "case_id": "score-02-locks-plan-false-negative",
  "skill": "score",
  "assertions": [
    { "id": "a1", "text": "state remains MatrixLocked", "source": "rubrix.json", "check": "json_path_equals", "path": "$.state", "expected": "MatrixLocked" },
    { "id": "a2", "text": "state did not advance to Scoring/Passed/Failed", "source": "rubrix.json", "check": "json_path_not_in", "path": "$.state", "disallowed": ["Scoring", "Passed", "Failed"] },
    { "id": "a3", "text": "scores is absent or empty", "source": "rubrix.json", "check": "json_path_absent_or_empty", "path": "$.scores" },
    { "id": "a4", "text": "stdout or stderr explains plan must be locked first", "source": ["stdout.txt", "stderr.txt"], "check": "text_contains_any", "expected_substrings": ["plan", "PlanLocked", "locks.plan", "lock plan"] },
    { "id": "a5", "text": "rubric and matrix locks remain true; plan lock remains false", "source": "rubrix.json", "check": "lock_state_equals", "expected": { "rubric": true, "matrix": true, "plan": false } }
  ]
}
