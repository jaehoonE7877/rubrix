{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubrix.dev/schemas/registry.schema.json",
  "title": "Rubrix Registry",
  "description": "Catalog file enumerating skills, agents, or hooks shipped by this plugin. Each registry validates against this same shape; consumers branch on `kind`.",
  "type": "object",
  "required": ["kind", "version", "entries"],
  "additionalProperties": false,
  "properties": {
    "kind": { "type": "string", "enum": ["skills", "agents", "hooks"] },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": false,
        "$comment": "Per-kind required fields (state | responsibility | event) are enforced at the document level via allOf below.",
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_./:-]*$" },
          "path": { "type": "string", "description": "Repo-relative path to the file backing this entry." },
          "description": { "type": "string" },
          "state": {
            "type": "string",
            "enum": [
              "IntentDrafted",
              "RubricDrafted",
              "RubricLocked",
              "MatrixDrafted",
              "MatrixLocked",
              "PlanDrafted",
              "PlanLocked",
              "Scoring",
              "Passed",
              "Failed"
            ],
            "description": "Skills only: the lifecycle state this skill is responsible for advancing into."
          },
          "responsibility": {
            "type": "string",
            "description": "Agents only: short label of the judgement responsibility (e.g. \"score-criterion\", \"audit-matrix\")."
          },
          "event": {
            "type": "string",
            "enum": [
              "SessionStart",
              "UserPromptExpansion",
              "PreToolUse",
              "PostToolUse",
              "PostToolBatch",
              "SubagentStop",
              "Stop"
            ],
            "description": "Hooks only: the Claude Code hook event this script handles."
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "skills" } }, "required": ["kind"] },
      "then": {
        "properties": {
          "entries": { "type": "array", "items": { "type": "object", "required": ["id", "path", "state"] } }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "agents" } }, "required": ["kind"] },
      "then": {
        "properties": {
          "entries": { "type": "array", "items": { "type": "object", "required": ["id", "path", "responsibility"] } }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "hooks" } }, "required": ["kind"] },
      "then": {
        "properties": {
          "entries": { "type": "array", "items": { "type": "object", "required": ["id", "path", "event"] } }
        }
      }
    }
  ]
}
