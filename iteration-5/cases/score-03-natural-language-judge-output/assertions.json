    { "id": "a4", "text": "criterion c3 score is below floor (0.7) because rollback policy is absent", "source": "rubrix.json", "check": "json_array_item_field_below", "path": "$.scores", "where": { "criterion": "c3" }, "field": "score", "threshold": 0.7 },
    { "id": "a5", "text": "c3 score notes mention rollback policy absence", "source": "rubrix.json", "check": "json_array_item_text_contains", "path": "$.scores", "where": { "criterion": "c3" }, "field": "notes", "expected_substrings": ["rollback"] }
  ]
