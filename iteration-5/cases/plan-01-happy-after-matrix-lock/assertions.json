    { "id": "a5", "text": "plan mentions verification or evidence in at least one step", "source": "rubrix.json", "check": "json_array_any_text_contains", "path": "$.plan.steps", "field": "action", "expected_substrings": ["verify", "verification", "evidence", "check"] }
